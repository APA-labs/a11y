{
  "name": "a11y-pattern-agent",
  "version": "0.0.1",
  "description": "AI-powered accessibility design assistant",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,jsx,json,md}\"",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "transform:rules": "pnpm --filter @a11y/spec-transformer transform",
    "transform:pattern": "pnpm --filter @a11y/spec-transformer transform:patterns",
    "verify:rules": "pnpm --filter @a11y/spec-transformer verify:rules",
    "verify:patterns": "pnpm --filter @a11y/spec-transformer verify:all",
    "postinstall": "command -v lefthook >/dev/null 2>&1 && lefthook install || true"
  },
  "workspaces": [
    "packages/*",
    "tools/*"
  ],
  "devDependencies": {
    "eslint": "^9.0.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
