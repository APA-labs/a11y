{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "**/.env.local"
  ],
  "globalEnv": [
    "ANTHROPIC_API_KEY",
    "LOG_LEVEL",
    "PORT",
    "HOST",
    "NODE_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build"
      ],
      "outputs": [
        "dist/**",
        ".next/**"
      ],
      "env": [
        "INDEXNOW_KEY",
        "NEXT_PUBLIC_SITE_URL"
      ]
    },
    "lint": {
      "outputs": []
    },
    "type-check": {
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "transform": {
      "cache": false
    }
  }
}